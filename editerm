    if not proj:
        return "no project found"
    print("undone" if proj.undo() else "nothing to undo")

def cmd_redo(_):
    proj = find_project()
    if not proj:
        return "no project found"
    print("redone" if proj.redo() else "nothing to redo")

def cmd_save(_):
    proj = find_project()
    if not proj:
        return "no project found"
    unapplied = [f for f in proj.features if not f.applied]
    if unapplied:
        try:
            ans = input(f"Do you want to apply {len(unapplied)} feature(s)? Y/n: ").strip().lower()
        except (EOFError, KeyboardInterrupt):
            ans = 'y'
        if ans in ('', 'y', 'yes'):
            for f in unapplied:
                f.applied = True
    proj.save()
    print("saved")

def cmd_prompt(_):
    proj = find_project()
    if not proj:
        return ""
    s = proj.name
    if len(s) > 30:
        s = s[:29] + "~"
    return f"({s})"

def cmd_ls(_):
    proj = find_project()
    if not proj:
        return "no project found"
    if not proj.clips:
        print("no clips")
        return
    for c in proj.clips:
        dur = c.end - c.start
        print(f"  {c.id}  {c.source}  [{format_ts(dur)}]  ({c.start}-{c.end}s)")

def next_feature_id(features, ftype):
    n = 1
    while True:
        fid = f"{ftype}{n}"
        if not any(f.id == fid for f in features):
            return fid
        n += 1

def validate_feature(ftype, raw_val):
    c = FEATURE_CONSTRAINTS.get(ftype)
    if not c:
        return None, f"unknown feature type '{ftype}'"
    try:
        v = int(raw_val)
    except ValueError:
        return None, f"'{ftype}' requires an integer value"
    if v < c['min'] or v > c['max']:
        return None, f"min and max options for {ftype}: {c['min']} | {c['max']}"
    return str(v), None

def cmd_feature(args):
    proj = find_project()
    if not proj:
        return "no project found"
    if args.action == 'list':
        mode = args.type_or_id
        if mode == 'applied':
            feats = [f for f in proj.features if f.applied]
            if not feats:
                print("(no features applied)")
            for f in feats:
                print(f"({f.id}: {f.value})")
            return
        if mode == 'unapplied':
            feats = [f for f in proj.features if not f.applied]
            if not feats:
                print("(no features unapplied)")
            for f in feats:
                print(f"({f.id}: {f.value})")
            return
        a = [f for f in proj.features if f.applied]
        u = [f for f in proj.features if not f.applied]
        print("A: " + (" ".join(f"({f.id}: {f.value})" for f in a) if a else "(no features applied)"))
        print("UA: " + (" ".join(f"({f.id}: {f.value})" for f in u) if u else "(no features unapplied)"))
        return
    if args.action == 'add':
        if not args.type_or_id or not args.value:
            return f"usage: editerm feature add <type> <value>\n       editerm feature set <id> <value>\n       editerm feature apply|unapply|remove <id>\n       editerm feature list [applied|unapplied]\n\ntypes: pitch (-12 to +12)"
        v, err = validate_feature(args.type_or_id, args.value)
        if err:
            return err
        fid = next_feature_id(proj.features, args.type_or_id)
        proj.features.append(Feature(fid, args.type_or_id, v, False))
        proj.save()
        print(f"added {fid} ({v})")
        return
    if args.action == 'set':
        if not args.type_or_id or not args.value:
            return f"usage: editerm feature set <id> <value>\n       editerm feature add <type> <value>\n       editerm feature apply|unapply|remove <id>\n       editerm feature list [applied|unapplied]\n\ntypes: pitch (-12 to +12)"
        feat = next((f for f in proj.features if f.id == args.type_or_id), None)
        if not feat:
            return f"feature '{args.type_or_id}' not found"
        if feat.applied:
            return f"'{args.type_or_id}' is applied, unapply it first"
        v, err = validate_feature(feat.type, args.value)
        if err:
            return err
        feat.value = v
        proj.save()
        print(f"set {feat.id} to {v}")
        return
    if args.action == 'apply':
        if not args.type_or_id:
            return "usage: editerm feature apply <id>"
        feat = next((f for f in proj.features if f.id == args.type_or_id), None)
        if not feat:
            return f"feature '{args.type_or_id}' not found"
        if feat.applied:
            return f"'{args.type_or_id}' already applied"
        feat.applied = True
        proj.save()
        print(f"applied {feat.id}")
        return
    if args.action == 'unapply':
        if not args.type_or_id:
            return "usage: editerm feature unapply <id>"
        feat = next((f for f in proj.features if f.id == args.type_or_id), None)
        if not feat:
            return f"feature '{args.type_or_id}' not found"
        if not feat.applied:
            return f"'{args.type_or_id}' not applied"
        feat.applied = False
        proj.save()
        print(f"unapplied {feat.id}")
        return
    if args.action == 'remove':
        if not args.type_or_id:
            return "usage: editerm feature remove <id>"
        feat = next((f for f in proj.features if f.id == args.type_or_id), None)
        if not feat:
            return f"feature '{args.type_or_id}' not found"
        proj.features.remove(feat)
        proj.save()
        print(f"removed {feat.id}")
        return

def cmd_settings(proj):
    s = proj.settings
    labels = [
        ('fps', f"FPS"),
        ('width', "Width"),
        ('height', "Height"),
        ('format', "Format"),
        ('vcodec', "Video codec"),
        ('crf', "CRF (0-51)"),
        ('pix_fmt', "Pixel format"),
        ('preset', "Preset"),
    ]
    while True:
        print(f"\nsettings for {proj.name}")
        print("-" * 30)
        for i, (k, label) in enumerate(labels, 1):
            print(f"  {i}. {label}: {s[k]}")
        print("  q. quit (save)")
        try:
            inp = input("> ").strip().lower()
        except (EOFError, KeyboardInterrupt):
            print()
            break
        if inp == 'q':
            break
        try:
            idx = int(inp) - 1
        except ValueError:
            continue
        if idx < 0 or idx >= len(labels):
            continue
        k, _ = labels[idx]
        raw = input(f"  {k} [{s[k]}]: ").strip()
        if not raw:
            continue
        orig = type(s[k])
        try:
            s[k] = orig(raw) if orig != str else raw
        except ValueError:
            continue
        proj.save()
    proj.save()

def main():
    parser = argparse.ArgumentParser(prog='editerm', description='terminal video editor')
    sub = parser.add_subparsers(dest='command')

    p = sub.add_parser('project')
    p.add_argument('action', choices=['new'])
    p.add_argument('name')

    p = sub.add_parser('add')
